#!/bin/bash
# gotrain: Atomic CLI for NYC train departures (MTA, LIRR, MNR)
# Uses MetroFlow API

set -e

API_BASE="https://metroflow.ainslie.digital/api/v1"
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/gotrain"
CACHE_TTL=60  # seconds

mkdir -p "$CACHE_DIR"

usage() {
  cat <<EOF
Usage: gotrain <command> [args]

Commands:
  stations [query]     List stations (filter by query)
  departures <id>      Show departures for a station
  alerts               Show active service alerts
  favorite <id>        Add/remove station from favorites
  favs                  List favorite stations

Examples:
  gotrain stations penn
  gotrain departures penna
  gotrain alerts

EOF
  exit 0
}

# API wrapper with caching
api_fetch() {
  local endpoint="$1"
  local cache_file="$CACHE_DIR/$(echo "$endpoint" | tr '/' '-')"
  local now=$(date +%s)

  # Check cache
  if [[ -f "$cache_file" ]]; then
    local mtime=$(stat -c %Y "$cache_file" 2>/dev/null || stat -f %m "$cache_file" 2>/dev/null)
    if [[ $((now - mtime)) -lt $CACHE_TTL ]]; then
      cat "$cache_file"
      return
    fi
  fi

  # Fetch and cache
  curl -s "${API_BASE}${endpoint}" | tee "$cache_file"
}

# Format time
format_time() {
  local dt="$1"
  if [[ -z "$dt" || "$dt" == "null" ]]; then
    echo "--"
    return
  fi
  date -d "$dt" +"%H:%M" 2>/dev/null || date -jf "%Y-%m-%dT%H:%M" "$dt" +"%H:%M" 2>/dev/null || echo "$dt"
}

cmd_stations() {
  local query="${1:-}"
  local endpoint="/stations"
  [[ -n "$query" ]] && endpoint="/stations?q=$query"

  echo "NYC Transit Stations"
  echo "====================="
  echo ""

  api_fetch "$endpoint" | jq -r '.[] | [.id, .name, (.system // "-")] | @tsv' 2>/dev/null | while IFS='|' read -r id name system; do
    case "$system" in
      SUBWAY) echo "🟦 SUBWAY | $name | $id" ;;
      LIRR) echo "🟩 LIRR | $name | $id" ;;
      MNR) echo "🟥 MNR | $name | $id" ;;
      *) echo "  $name | $id" ;;
    esac
  done
}

cmd_departures() {
  local station_id="${1:-}"
  [[ -z "$station_id" ]] && { echo "Usage: gotrain departures <station-id>"; exit 1; }

  echo "Departures for $station_id"
  echo "==========================="
  echo ""

  api_fetch "/departures/$station_id" | jq -r '.[] | "\(.routeShortName // "-")|\(.destination)|\(.departureTime)|\(.status)|\(.track // "-")"' 2>/dev/null | while IFS='|' read -r route dest time status track; do
    local time_fmt=$(format_time "$time")
    local icon="🟢"
    [[ "$status" == *"Delayed"* ]] && icon="🟡"
    [[ "$status" == *"Due"* ]] && icon="🟢"

    echo "$time_fmt | $route → $dest $icon"
    echo "      Track: $track | $status"
  done
}

cmd_alerts() {
  echo "Active Service Alerts"
  echo "======================"
  echo ""

  api_fetch "/alerts?activeNow=true&includeLabels=true" | jq -r '.[] | "\(.title)|\(.description[0:100])"' 2>/dev/null | while IFS='|' read -r title desc; do
    echo "⚠️  $title"
    echo "   $desc..."
    echo ""
  done
}

cmd_favorite() {
  local id="${1:-}"
  [[ -z "$id" ]] && { echo "Usage: gotrain favorite <station-id>"; exit 1; }

  local fav_file="$CACHE_DIR/favorites"
  if grep -q "^$id$" "$fav_file" 2>/dev/null; then
    grep -v "^$id$" "$fav_file" > "$fav_file.tmp" && mv "$fav_file.tmp" "$fav_file"
    echo "Removed $id from favorites"
  else
    echo "$id" >> "$fav_file"
    echo "Added $id to favorites"
  fi
}

cmd_favs() {
  echo "Favorite Stations"
  echo "=================="
  echo ""

  local fav_file="$CACHE_DIR/favorites"
  [[ ! -f "$fav_file" ]] && { echo "No favorites yet. Use 'gotrain favorite <id>' to add."; exit 0; }

  while read -r id; do
    [[ -z "$id" ]] && continue
    api_fetch "/stations?q=$id" | jq -r --arg id "$id" '.[] | select(.id == $id) | "\(.id)|\(.name)|\(.system)"' 2>/dev/null | while IFS='|' read -r sid name system; do
      case "$system" in
        SUBWAY) echo "🟦 SUBWAY | $name ($sid)" ;;
        LIRR) echo "🟩 LIRR | $name ($sid)" ;;
        MNR) echo "🟥 MNR | $name ($sid)" ;;
        *) echo "  $name ($sid)" ;;
      esac
    done
  done < "$fav_file"
}

# Main
[[ $# -eq 0 ]] && usage

case "$1" in
  stations|s) cmd_stations "${2:-}" ;;
  departures|d) cmd_departures "$2" ;;
  alerts|a) cmd_alerts ;;
  favorite|fav) cmd_favorite "$2" ;;
  favs|favorites) cmd_favs ;;
  -h|--help|help) usage ;;
  *) echo "Unknown command: $1"; usage ;;
esac
